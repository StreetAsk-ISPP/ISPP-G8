# StreetAsk Environment Variables
# Copy this file to .env and fill in your values
# Usage: docker-compose up -d

# ===================
# MySQL Configuration
# ===================
# Root password for MySQL (only used locally)
MYSQL_ROOT_PASSWORD=rootpassword

# Database name
MYSQL_DATABASE=streetask

# Database user credentials
MYSQL_USER=streetask
MYSQL_PASSWORD=streetask

# ===================
# Azure Production (Optional - for reference)
# ===================
# When deploying to Azure, set these in Azure App Service configuration:
# MYSQL_URL=jdbc:mysql://your-azure-mysql.mysql.database.azure.com:3306/streetask?useSSL=true&requireSSL=true
# MYSQL_USER=your-azure-user@your-azure-mysql
# MYSQL_PASSWORD=your-azure-password
